{% extends 'main.html' %}
{% load static %}

{% block content %}
<main class="site-main relative ml-0 md:ml-[0] min-w-0 flex-1 overflow-auto">
  <div class="hero">
    <div class="hero-eyebrow"><span></span> Gobonimo Marketplace</div>
    <h1>Buy, sell &amp; discover<br><em>everything local</em></h1>
    <p class="hero-sub">From property and vehicles to electronics and fashion — find the best deals in your city.</p>

    <!-- ── 3-FIELD SEARCH ──────────── -->
    <div class="hero-search-box">
      <form method="GET" action="{% url 'search_ads' %}">
        <div class="hero-search-fields">

          <!-- Category dropdown -->
          <div class="hero-cat-wrap">
            <button type="button" class="hero-cat-btn" id="heroCatBtn">
              <span id="heroCatLabel">Select category</span>
              <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="hero-cat-menu" id="heroCatMenu">
              {% for category in categories %}
              <button type="button" class="hero-cat-item" data-value="{{ category.id }}" data-label="{{ category.name }}">
                {% if category.icon == 'building' %}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="3" y="6.5" width="18" height="11" rx="1.2" stroke="#4ea2ff" stroke-width="1.4"/><path d="M9 10h1m-1 3h1m3-3h1m-1 3h1m3-3h1m-1 3h1" stroke="#4ea2ff" stroke-width="1.4" stroke-linecap="round"/></svg>
                {% elif category.icon == 'land' %}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M3 10l9-9 9 9M6 10v9a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-9" stroke="#22c55e" stroke-width="1.4"/><rect x="8" y="12" width="2" height="2" rx="0.5" fill="#22c55e"/><rect x="12" y="12" width="2" height="2" rx="0.5" fill="#22c55e"/><rect x="16" y="12" width="2" height="2" rx="0.5" fill="#22c55e"/></svg>
                {% elif category.icon == 'electronics' %}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="4" y="4" width="16" height="16" rx="2" stroke="#a855f7" stroke-width="1.4"/><circle cx="12" cy="10" r="1" fill="#a855f7"/><rect x="8" y="13" width="8" height="2" rx="1" fill="#a855f7"/></svg>
                {% elif category.icon == 'fashion' %}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 12h4.5a3.5 3.5 0 1 1 0 7H12V12z" stroke="#ec4899" stroke-width="1.4"/><path d="M12 12H7.5a3.5 3.5 0 1 0 0 7H12V12z" stroke="#ec4899" stroke-width="1.4"/><circle cx="12" cy="9" r="1.5" fill="#ec4899"/></svg>
                {% elif category.icon == 'car' %}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 13l1.5-4.5A2 2 0 0 1 8.5 7h7a2 2 0 0 1 2 1.5L19 13M5 13h14M5 13v5a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1v-1m8 1v1a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-1m0 0H9" stroke="#f97316" stroke-width="1.4"/><circle cx="8" cy="17" r="1" fill="#f97316"/><circle cx="16" cy="17" r="1" fill="#f97316"/></svg>
                {% elif category.icon == 'wrench' %}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" stroke="#eab308" stroke-width="1.4"/></svg>
                {% elif category.icon == 'briefcase' %}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="2" y="7" width="20" height="14" rx="2" stroke="#6366f1" stroke-width="1.4"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" stroke="#6366f1" stroke-width="1.4"/></svg>
                {% elif category.icon == 'scissors' %}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><circle cx="6" cy="6" r="3" stroke="#ef4444" stroke-width="1.4"/><circle cx="6" cy="18" r="3" stroke="#ef4444" stroke-width="1.4"/><path d="M20 4L8.12 15.88M14.47 14.48L20 20M8.12 8.12L12 12" stroke="#ef4444" stroke-width="1.4"/></svg>
                {% elif category.icon == 'paint-brush' %}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M21 7v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke="#14b8a6" stroke-width="1.4"/></svg>
                {% else %}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8" stroke="#9ca3af" stroke-width="1.4"/></svg>
                {% endif %}
                {{ category.name }}
              </button>
              {% endfor %}
            </div>
            <input type="hidden" name="category" id="heroCatValue">
          </div>

          <!-- Keyword -->
          <input class="hero-input" type="search" name="q"
            placeholder="Keyword — car, apartment, phone…"
            value="{{ request.GET.q|default:'' }}" autocomplete="off">

          <!-- Location -->
          <input class="hero-input" type="text" name="location"
            placeholder="Location — city or area"
            value="{{ request.GET.location|default:'' }}" class="hero-input hero-input-loc">

          <!-- Submit -->
          <button type="submit" class="hero-search-btn">
            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="5"/><path d="M21 21l-4.35-4.35" stroke-linecap="round"/></svg>
            Search
          </button>
        </div>
      </form>
    </div>

    <div class="hero-stats">
      <div class="hero-stat">
        <div class="hero-stat-num">{{ categories|length }}+</div>
        <div class="hero-stat-label">Categories</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">{{ featured_products|length }}+</div>
        <div class="hero-stat-label">Featured Ads</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">100%</div>
        <div class="hero-stat-label">Free to Browse</div>
      </div>
    </div>
  </div>

  <!-- ── CATEGORY PILLS ────────────────────────────────── -->
  <div class="cat-pills">
    <a href="{% url 'index' %}" class="pill active">All</a>
    {% for category in categories %}
    <a href="{% url 'category_detail' category.id %}" class="pill">{{ category.name }}</a>
    {% endfor %}
  </div>

  <!-- ── FILTER BAR ─────────────────────────────────────── -->
  <div class="filter-bar">
    <input id="filterInput" placeholder="Filter listings…" autocomplete="off">
    <div class="filter-count">Showing <strong id="assetCount">0</strong> listings</div>
  </div>

  <!-- ── LISTINGS ───────────────────────────────────────── -->
  <div class="px-4 md:px-6 py-5">
    {% for category in categories %}
      {% if category.approved_ads %}
      <div class="cat-section" data-category-name="{{ category.name|lower }}">

        <div class="section-head">
          <span class="section-title">{{ category.name }}</span>
          <a href="{% url 'category_detail' category.id %}" class="see-all">View all →</a>
        </div>

        <div class="scroll-row">
          <div class="cards-flex">
            {% for product in category.approved_ads %}
            <article class="asset-card"
              data-name="{{ product.name|lower }}"
              data-category="{{ product.category.name|default:''|lower }}"
              data-location="{{ product.location|default:''|lower }}">

              <!-- IMAGE LINK — separate <a> with class for display:block -->
              <a class="card-img-link" href="{% url 'product_detail' product.id %}">
                <div class="card-img">
                  {% if product.images.first %}
                    <img src="{{ product.images.first.image.url }}" alt="{{ product.name }}" loading="lazy" draggable="false">
                  {% else %}
                    <div class="placeholder-img"><i class="fas fa-image"></i></div>
                  {% endif %}
                  {% if product.is_featured %}<span class="badge-featured">⭐ Featured</span>{% endif %}
                  <span class="badge-price">${{ product.price }}</span>
                </div>
              </a>

              <div class="card-body">
                <div class="card-name" title="{{ product.name }}">{{ product.name }}</div>
                <div class="card-meta">
                  <span><i class="fas fa-map-marker-alt"></i>{{ product.location|default:"No location" }}</span>
                  <span><i class="far fa-clock"></i>{{ product.created_at|timesince }} ago</span>
                </div>
                <div class="card-foot">
                  <span class="card-tag">{{ product.category.name }}</span>
                  <a href="{% url 'product_detail' product.id %}" class="card-btn">View →</a>
                </div>
              </div>
            </article>
            {% endfor %}
          </div>
        </div>

      </div>
      {% endif %}
    {% empty %}
      <div class="empty-row">
        No listings yet. <a href="{% url 'menu' %}" style="color:#3b82f6">Post the first ad →</a>
      </div>
    {% endfor %}
  </div>

</main>

<script>
(function () {
  /* ── Hero category dropdown ── */
  const btn   = document.getElementById('heroCatBtn');
  const menu  = document.getElementById('heroCatMenu');
  const label = document.getElementById('heroCatLabel');
  const val   = document.getElementById('heroCatValue');

  btn.addEventListener('click', () => {
    const open = menu.classList.toggle('open');
    btn.classList.toggle('open', open);
  });

  document.querySelectorAll('.hero-cat-item').forEach(item => {
    item.addEventListener('click', () => {
      label.textContent = item.dataset.label;
      val.value = item.dataset.value;
      menu.classList.remove('open');
      btn.classList.remove('open');
    });
  });

  document.addEventListener('click', e => {
    if (!btn.contains(e.target) && !menu.contains(e.target)) {
      menu.classList.remove('open');
      btn.classList.remove('open');
    }
  });

 document.querySelectorAll(".scroll-row").forEach((slider) => {

    let isDown = false;
    let isDragging = false;
    let startX;
    let scrollLeft;

    slider.style.cursor = "grab";

    slider.addEventListener("mousedown", (e) => {
        isDown = true;
        isDragging = false;

        startX = e.pageX;
        scrollLeft = slider.scrollLeft;

        slider.style.cursor = "grabbing";
    });

    slider.addEventListener("mousemove", (e) => {

        if (!isDown) return;

        const walk = e.pageX - startX;

        if (Math.abs(walk) > 5) {
            isDragging = true;
        }

        slider.scrollLeft = scrollLeft - walk;
    });

    window.addEventListener("mouseup", () => {
        isDown = false;
        slider.style.cursor = "grab";
    });

    slider.querySelectorAll("a").forEach(link => {

        link.addEventListener("click", (e) => {

            if (isDragging) {
                e.preventDefault();
                e.stopPropagation();
            }

        });

    });

});

  /* ── Filter bar ── */
  const filterInput = document.getElementById('filterInput');
  const assetCount  = document.getElementById('assetCount');
  const allCards    = () => document.querySelectorAll('.asset-card');
  const allSections = () => document.querySelectorAll('.cat-section');

  function updateCount() {
    const visible = document.querySelectorAll('.asset-card:not([style*="display: none"])').length;
    assetCount.textContent = visible;
  }

  // Initial count
  updateCount();

  filterInput && filterInput.addEventListener('input', () => {
    const q = filterInput.value.toLowerCase().trim();
    allCards().forEach(card => {
      const match = !q
        || card.dataset.name.includes(q)
        || card.dataset.category.includes(q)
        || card.dataset.location.includes(q);
      card.style.display = match ? '' : 'none';
    });
    // Hide empty sections
    allSections().forEach(section => {
      const hasVisible = [...section.querySelectorAll('.asset-card')].some(c => c.style.display !== 'none');
      section.style.display = hasVisible ? '' : 'none';
    });
    updateCount();
  });
})();
</script>

{% endblock %}

<script>
(function () {

  /* ── hero category dropdown ───────────────────────────── */
  const btn   = document.getElementById('heroCatBtn');
  const menu  = document.getElementById('heroCatMenu');
  const label = document.getElementById('heroCatLabel');
  const val   = document.getElementById('heroCatValue');

  btn.addEventListener('click', () => {
    menu.classList.toggle('open');
    btn.classList.toggle('open');
  });

  menu.querySelectorAll('.hero-cat-item').forEach(item => {
    item.addEventListener('click', () => {
      label.textContent = item.dataset.label;
      val.value = item.dataset.value;
      menu.classList.remove('open');
      btn.classList.remove('open');
    });
  });

  document.addEventListener('click', e => {
    if (!btn.contains(e.target) && !menu.contains(e.target)) {
      menu.classList.remove('open');
      btn.classList.remove('open');
    }
  });

  /* ── drag-to-scroll ──────────────────────────────────── */
  document.querySelectorAll('.scroll-row').forEach(el => {
    let isDown = false, startX, scrollLeft;
    el.addEventListener('mousedown', e => {
      isDown = true;
      el.classList.add('dragging');
      startX = e.pageX - el.offsetLeft;
      scrollLeft = el.scrollLeft;
    });
    document.addEventListener('mouseup', () => { isDown = false; el.classList.remove('dragging'); });
    el.addEventListener('mouseleave', () => { isDown = false; el.classList.remove('dragging'); });
    el.addEventListener('mousemove', e => {
      if (!isDown) return;
      e.preventDefault();
      el.scrollLeft = scrollLeft - (e.pageX - el.offsetLeft - startX) * 1.4;
    });
  });

  /* ── filter + count ──────────────────────────────────── */
  const input   = document.getElementById('filterInput');
  const countEl = document.getElementById('assetCount');

  function updateCount() {
    countEl.textContent = document.querySelectorAll('.asset-card:not([style*="display: none"])').length;
  }
  updateCount();

  if (input) {
    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      document.querySelectorAll('.asset-card').forEach(card => {
        const match = !q
          || (card.dataset.name||'').includes(q)
          || (card.dataset.category||'').includes(q)
          || (card.dataset.location||'').includes(q);
        card.style.display = match ? '' : 'none';
      });
      document.querySelectorAll('.cat-section').forEach(sec => {
        const visible = sec.querySelectorAll('.asset-card:not([style*="display: none"])').length;
        sec.style.display = visible > 0 ? '' : 'none';
      });
      updateCount();
    });
  }

})();
</script>


<script>
(function () {
  // ── drag-to-scroll ──────────────────────────────────────
  document.querySelectorAll('.scroll-row').forEach(el => {
    let isDown = false, startX, scrollLeft;
    el.addEventListener('mousedown', e => {
      isDown = true;
      el.classList.add('dragging');
      startX = e.pageX - el.offsetLeft;
      scrollLeft = el.scrollLeft;
    });
    document.addEventListener('mouseup', () => { isDown = false; el.classList.remove('dragging'); });
    el.addEventListener('mouseleave', () => { isDown = false; el.classList.remove('dragging'); });
    el.addEventListener('mousemove', e => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - el.offsetLeft;
      el.scrollLeft = scrollLeft - (x - startX) * 1.4;
    });
  });

  // ── filter + count ──────────────────────────────────────
  const input = document.getElementById('filterInput');
  const countEl = document.getElementById('assetCount');

  function updateCount() {
    const visible = document.querySelectorAll('.asset-card:not([style*="display: none"])').length;
    countEl.textContent = visible;
  }

  // initial count
  updateCount();

  if (input) {
    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      document.querySelectorAll('.asset-card').forEach(card => {
        const name = card.dataset.name || '';
        const cat  = card.dataset.category || '';
        const loc  = card.dataset.location || '';
        const show = !q || name.includes(q) || cat.includes(q) || loc.includes(q);
        card.style.display = show ? '' : 'none';
      });

      // hide empty sections
      document.querySelectorAll('.category-section').forEach(section => {
        const visible = section.querySelectorAll('.asset-card:not([style*="display: none"])').length;
        section.style.display = visible > 0 ? '' : 'none';
      });

      updateCount();
    });
  }

  // ── mobile overlay close ────────────────────────────────
  const overlay = document.getElementById('mobileOverlay');
  const sidebar = document.getElementById('mobileSidebar');
  if (overlay && sidebar) {
    overlay.addEventListener('click', () => sidebar.classList.add('hidden'));
  }
})();
</script>

